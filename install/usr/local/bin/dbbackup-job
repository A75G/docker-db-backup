#!/usr/bin/env bash
set -eo pipefail

instance_raw="${1:-}"
job_mode="${2:-}"

if [ -z "${instance_raw}" ] ; then
    echo "usage: $(basename "$0") <instance> [now]" >&2
    exit 64
fi

instance="$(printf '%02d' "${instance_raw#0}")"

source /assets/functions/01-dbbackup-compat
source /assets/defaults/10-db-backup
source /assets/functions/10-db-backup

PROCESS_NAME="db-backup${instance}-scheduler"
bootstrap_variables backup_init "${instance}"
bootstrap_variables parse_variables "${instance}"

if [ -z "${backup_job_db_name}" ]; then
    PROCESS_NAME="${instance}-${backup_job_db_host//\//_}"
else
    PROCESS_NAME="${instance}-${backup_job_db_host//\//_}__${backup_job_db_name}"
fi

trap ctrl_c INT

if [[ "${MODE,,}" =~ standalone ]] || [ "${MODE,,}" = "manual" ] || [ "${job_mode,,}" = "manual" ] || [ "${job_mode,,}" = "now" ]; then
    print_debug "Detected Manual Mode"
    persist=false
    backup_job_backup_begin=+0
else
    persist=true
    sleep "${instance#0}"
    time_last_run=0
    time_current=$(date +'%s')
    if [[ "${backup_job_backup_begin}" =~ ^\+(.*)$ ]]; then
        print_debug "BACKUP_BEGIN is a jump of minute starting with +"
        timer plusvalue
    elif [[ "${backup_job_backup_begin}" =~ ^[0-9]{4}$ ]]; then
        print_debug "BACKUP_BEGIN is a HHMM value"
        timer time
    elif [[ "${backup_job_backup_begin}" =~ ([0-9]{4})-([0-9]{2})-([0-9]{2})[[:space:]]([0-9]{2}):([0-9]{2}):([0-9]{2}) ]]; then
        print_debug "BACKUP_BEGIN is a full date timestamp"
        timer datetime
    elif echo "${backup_job_backup_begin//\*/#}" | grep -qP "^(((\d+,)+\d+|(\d+(\/|-)\d+)|\d+|#) ?){5}$" ; then
        print_debug "BACKUP_BEGIN is a cron expression"
        time_last_run=$(date +"%s")
        backup_job_backup_begin=${backup_job_backup_begin//\"/}
        backup_job_backup_begin=${backup_job_backup_begin//\'/}
        timer cron "${backup_job_backup_begin}" "${time_current}" "${time_last_run}"
    else
        print_error "_BACKUP_BEGIN is invalid - Unable to perform scheduling"
        cat <<EOF

        Valid Methods:
          +(number)             - Start in however many minutes
          HHMM                  - Start at hour (00-24) and minute (00-59)
          YYYY-MM-DD HH:mm:ss   - Start at a specific date and time
          0 23 * * *            - Cron expression

EOF
        stop_scheduler_backup=true
    fi

    if var_nottrue "${stop_scheduler_backup:-false}" ; then
        print_debug "Wait Time: ${time_wait} Future execution time: ${time_future} Current Time: ${time_current}"
        print_info "Next Backup at $(date -d @"${time_future}" +'%Y-%m-%d %T %Z')"
        silent sleep "${time_wait}"
    fi
fi

while true; do
    blackout=false
    if [ -n "${backup_job_blackout_start:-}" ] && [ -n "${backup_job_blackout_finish:-}" ] ; then
        time_current_hour_minute=$(date +%H%M)
        if [[ "${time_current_hour_minute}" > "${backup_job_blackout_start}" ]] && [[ "${time_current_hour_minute}" < "${backup_job_blackout_finish}" ]] ; then
            blackout=true
        fi
    fi

    if var_true "${blackout}" ; then
        print_notice "Detected Blackout Period - Not performing backup operations"
    else
        timer job start
        process_limiter
        echo "${instance}" >> /tmp/.container/db-backup-backups
        print_debug "Backup ${instance} routines started time: $(date +'%Y-%m-%d %T %Z')"
        bootstrap_filesystem
        check_availability
        backup_"${dbtype,,}"
        timer job stop
        if [ -z "${exitcode_backup:-}" ] ; then exitcode_backup="0" ; fi
        print_info "Backup ${instance} routines finish time: $(date -d @"${backup_job_finish_time}" +'%Y-%m-%d %T %Z') with exit code ${exitcode_backup}"
        print_notice "Backup ${instance} routines time taken: $(echo "${backup_job_total_time}" | awk '{printf "Hours: %d Minutes: %02d Seconds: %02d", $1/3600, ($1/60)%60, $1%60}')"
        sed -i "/^${instance}/d" /tmp/.container/db-backup-backups
    fi

    symlink_log

    if var_false "${persist}" ; then
        print_debug "Exiting due to manual mode"
        exit "${exitcode_backup:-0}"
    fi

    if var_true "${stop_scheduler_backup:-false}" ; then
        print_error "Stopping backup scheduler ${instance} due to detected errors."
        exit 1
    fi

    if [ ! "${time_cron:-false}" = "true" ]; then
        sleep_for=$((backup_job_backup_interval * 60 - backup_job_total_time))
        if [ "${sleep_for}" -lt 0 ] ; then
            sleep_for=0
        fi
        print_notice "Sleeping for another ${sleep_for} seconds. Waking up at $(date -d@"$(( $(date +%s) + sleep_for ))" +'%Y-%m-%d %T %Z')"
        silent sleep "${sleep_for}"
    else
        time_current=$(date +"%s")
        time_last_run=$(date +"%s")
        timer cron "${backup_job_backup_begin}" "${time_current}" "${time_last_run}"
        print_notice "Sleeping for another ${time_wait} seconds. Waking up at $(date -d@"${time_future}" +'%Y-%m-%d %T %Z')"
        silent sleep "${time_wait}"
    fi
done
