#!/bin/bash

# Repo-owned build helpers used by the Dockerfile after removal of the
# inherited tiredofit compatibility layer.

dbbackup_build_output_off() {
    if [ "${DEBUG_MODE,,}" = "true" ] ; then
        set +x
    fi
}

dbbackup_build_output_on() {
    if [ "${DEBUG_MODE,,}" = "true" ] ; then
        set -x
    fi
}

package() {
    cleanup() {
        case "${distro}" in
            "alpine" )
                rm -rf /root/.gitconfig
                rm -rf /var/cache/apk/*
            ;;
            "debian" | "ubuntu" )
                apt-get clean -y
                rm -rf /root/.gitconfig
                rm -rf /var/lib/apt/lists/*
            ;;
        esac
    }

    install() {
        case "${distro}" in
            "alpine" )
                if [[ "${1}" =~ ^\..* ]] ; then
                    local dependencies="-t"
                fi
                apk add ${dependencies} "$@"
            ;;
            "debian" | "ubuntu" )
                if [[ "${1}" =~ ^\..* ]] ; then
                    shift
                fi
                apt-get install -y --no-install-recommends "$@"
            ;;
        esac
    }

    remove() {
        case "${distro}" in
            "alpine" )
                apk del "$@"
            ;;
            "debian" | "ubuntu" )
                local packages="$*"
                if [[ "${packages}" =~ \..* ]] ; then
                    packages=$(echo "${packages}" | sed "s|\..* ||g")
                fi
                apt-get purge -y ${packages}
                apt-get autoremove -y
            ;;
        esac
    }

    update() {
        case "${distro}" in
            "alpine" )
                apk update
            ;;
            "debian" | "ubuntu" )
                apt-get update
            ;;
        esac
    }

    upgrade() {
        case "${distro}" in
            "alpine" )
                apk upgrade
            ;;
            "debian" | "ubuntu" )
                apt-get upgrade -y
            ;;
        esac
    }

    dbbackup_build_output_off
    local distro
    distro=$(grep '^ID=' /etc/os-release | cut -d = -f2)
    local action="${1}"
    shift

    case "${action}" in
        add | install )
            install "$@"
        ;;
        delete | remove | uninstall )
            remove "$@"
        ;;
        * )
            "${action}" "$@"
        ;;
    esac
    dbbackup_build_output_on
}

clone_git_repo() {
    if ! command -v git >/dev/null 2>&1; then
        echo "[clone_git_repo] Git is not installed"
        exit 1
    fi

    git config --global init.defaultBranch main

    if [ -z "$1" ] ; then
        echo "[clone_git_repo] You tried to call the function but there's no arguments"
        exit 1
    fi

    local repo repo_name repo_text append_git_prefix

    if [ -n "${3}" ] ; then
        repo="${3}/"
        repo_text="to '${3}'"
        repo_name="$(echo "${1,,}" | sed -e "s|-|_|g" -e "s|\.git||g" | awk -F/ '{print $NF}' | sed 's/[^a-zA-Z0-9_]//g')"
    else
        repo="/usr/src/$(echo "${1,,}" | sed -e "s|-|_|g" -e "s|\.git||g" | awk -F/ '{print $NF}' | sed 's/[^a-zA-Z0-9_]//g')"
        repo_name="$(echo "${1,,}" | sed -e "s|-|_|g" -e "s|\.git||g" | awk -F/ '{print $NF}' | sed 's/[^a-zA-Z0-9_]//g')"
    fi

    export GIT_REPO_SRC=${GIT_REPO_SRC:-"${repo}"}
    export GIT_REPO_SRC_${repo_name^^}="${repo}"

    if [ -d "${repo}" ] ; then
        echo "[clone_git_repo] Directory ${repo} already exists. Cannot clone"
        exit 1
    fi

    if [[ "$1" != *".git" ]] ; then
        append_git_prefix=".git"
    fi

    mkdir -p "${repo}"
    cd "${repo}"
    git init .
    git remote add origin "${1}${append_git_prefix}"
    echo "[clone_git_repo] Cloning Git Repo '${1}' '${2}' ${repo_text}"
    git fetch --depth=1 origin ${2} +refs/tags/*:refs/tags/*
    git fetch --depth=1 origin ${2}
    git -c advice.detachedHead=false checkout FETCH_HEAD
    git submodule update --init
}
